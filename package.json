{
  "name": "world-of-claudecraft",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "VAELORIA — a WoW-Classic-style micro-MMO + headless RL training environment",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build_media_manifest.mjs generate && vite build && node scripts/build_media_manifest.mjs emit",
    "preview": "vite preview",
    "test": "vitest run",
    "build:env": "esbuild headless/env_server.ts --bundle --platform=node --format=cjs --outfile=dist-env/env_server.cjs",
    "env": "npm run build:env && node dist-env/env_server.cjs",
    "bench": "npm run build:env && node dist-env/env_server.cjs --bench",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "build:server": "esbuild server/main.ts --bundle --platform=node --format=cjs --external:pg-native --external:bufferutil --external:utf-8-validate --outfile=dist-server/server.cjs",
    "server": "npm run build:server && node --env-file-if-exists=.env dist-server/server.cjs",
    "realms": "npm run build:server && node --env-file-if-exists=.env scripts/dev-realms.mjs",
    "admin:grant": "node scripts/grant_admin.mjs"
  },
  "dependencies": {
    "@privy-io/node": "^0.21.0",
    "@privy-io/react-auth": "^3.30.0",
    "@solana-program/memo": "^0.10.0",
    "@solana/kit": "^5.5.1",
    "n8ao": "^1.10.1",
    "pg": "^8.21.0",
    "postprocessing": "^6.36.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.165.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.4.0",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.165.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "esbuild": "^0.28.1",
    "puppeteer-core": "^25.1.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
